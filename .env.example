# Bearer token for the REST API (auto-generated on first boot if empty)
API_TOKEN=

# REST API host/port (defaults: 127.0.0.1 / 8080)
HOST=127.0.0.1
PORT=8080

# Optional: HTTP endpoint to POST inbound messages to.
# Leave empty to disable the webhook.
WEBHOOK_URL=

# Optional: bearer token sent as Authorization header to WEBHOOK_URL.
WEBHOOK_TOKEN=

# Optional: OpenAI API key. When set, inbound voice notes (audio messages) are
# transcribed via Whisper and the transcript is folded into the message body
# wherever the API is read (web UI, MCP, /v1/messages). Audio bodies are
# uploaded to api.openai.com — leave blank to disable.
OPENAI_API_KEY=

# Set to 1 ONLY after putting whatsapp-bridge behind a TLS-terminating reverse proxy
# (e.g. Caddy). Without this flag, the daemon refuses to bind a non-loopback HOST.
WA_ALLOW_PUBLIC=
